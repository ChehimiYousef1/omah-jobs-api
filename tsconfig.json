{
  "compilerOptions": {
  "outDir": "./dist",
  "module": "nodenext",
  "target": "ES2022",
  "moduleResolution": "nodenext",
  "esModuleInterop": true,
  "strict": true
},
  "include": ["src/**/*", "routes/**/*", "config/**/*", "controllers/**/*", "services/**/*", "utils/**/*"],
  "exclude": ["node_modules", "dist"]
}
